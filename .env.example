# ============================================================
# SIEL crawler — local DB credentials for auto-patch hook
# ============================================================
# How to use:
#   1. Copy this template:  copy .env.example .env
#   2. Fill in the 5 values below, save
#   3. Run scripts\setup-auto-patch.bat once per machine
#   4. From now on `git pull` auto-applies DB schema patches
#
# .env is gitignored — credentials stay local.
# ============================================================

PGPASSWORD=PUT_YOUR_PASSWORD_HERE
PGHOST=PUT_YOUR_DB_HOST_HERE
PGPORT=5432
PGUSER=postgres
PGDATABASE=postgres
